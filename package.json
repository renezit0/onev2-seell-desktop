{
  "name": "onev2-seell",
  "version": "0.1.0",
  "description": "oneV2 seeLL desktop com Electron, renderer desacoplado, IPC seguro e auto-update.",
  "author": "",
  "license": "MIT",
  "main": "electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config renderer/vite.config.js",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electronmon electron/main/main.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build --config renderer/vite.config.js",
    "build:electron": "electron-builder --dir",
    "pack:win": "npm run build:renderer && electron-builder --win nsis --publish never",
    "dist:win": "npm run build:renderer && electron-builder --win nsis --publish always",
    "release:win": "npm run build:renderer && electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electronmon": "^2.0.2",
    "vite": "^5.4.21",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.seell.onev2",
    "productName": "oneV2 seeLL",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "asar": true,
    "extraMetadata": {
      "main": "electron/main/main.js"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "renezit0",
        "repo": "onev2-seell-desktop"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "onev2-seell-desktop-SETUP.${ext}",
      "icon": "resources/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "differentialPackage": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "resources/icons/icon.ico",
      "uninstallerIcon": "resources/icons/icon.ico",
      "installerHeaderIcon": "resources/icons/icon.ico"
    },
    "icon": "resources/icons/icon.png",
    "mac": {
      "icon": "resources/icons/icon.icns"
    }
  }
}
